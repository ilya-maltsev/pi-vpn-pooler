# pi-vpn-pooler production environment
# Generate secrets with: make secrets

DJANGO_SECRET_KEY=changeme
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=https://localhost:5443

PI_API_URL=https://host.docker.internal:8443
PI_VERIFY_SSL=false
PI_REQUIRE_OTP=false

POOLS_FILE=/app/data/pools.yaml

DJANGO_LOG_LEVEL=INFO

# Default UI language fallback (only applies when the visitor has no
# session/cookie selection and no matching Accept-Language header). Must be
# one of the codes listed in settings.LANGUAGES (currently: en, ru).
DJANGO_LANGUAGE_CODE=en

PROXY_PORT=5443
SERVERNAME=localhost
